# Shared dev Postgres infrastructure — copy to .env (gitignored).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_PORT=5433

MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

ADMINER_PORT=8081

# pgAdmin (login email/password + UI port)
PGADMIN_PORT=8082
PGADMIN_EMAIL=admin@admin.com
PGADMIN_PASSWORD=password

# CloudBeaver (DBeaver web) UI port
CLOUDBEAVER_PORT=8978
